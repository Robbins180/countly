import { useEffect, useMemo, useState } from "react";
import { countersRepo, type Counter, type CounterCategoryKey } from "../data";
import { MS_DAY } from "../utils/date";

export interface InsightSegment {
  label: string;
  value: number;
  color: string;
}

export interface WeeklyInsights {
  total: number;
  activeDays: number;
  topCounter: string;
  lastWeekTotal: number;
  segments: InsightSegment[];
  change: number;
  changePercent: number;
  isUp: boolean;
}

// Map category keys → label + color for the donut
const CATEGORY_META: Record<CounterCategoryKey, { label: string; color: string }> = {
  work:    { label: "Work",              color: "#4f46e5" }, // indigo
  health:  { label: "Health & Wellness", color: "#10b981" }, // emerald
  home:    { label: "Home & Chores",     color: "#f59e0b" }, // amber
  personal:{ label: "Personal",          color: "#8b5cf6" }, // purple-ish
  other:   { label: "Other",             color: "#9ca3af" }, // gray
};

export function useInsightMockData(): WeeklyInsights {
  const [counters, setCounters] = useState<Counter[]>([]);

  // Load all counters once for now
  useEffect(() => {
    countersRepo
      .all()
      .then(setCounters)
      .catch((err) => {
        console.error("Failed to load counters for insights", err);
      });
  }, []);

  const {
    total,
    activeDays,
    topCounter,
    lastWeekTotal,
    segments,
    change,
    changePercent,
    isUp,
  } = useMemo(() => {
    const now = Date.now();
    const startOfThisWeek = now - 7 * MS_DAY;
    const startOfLastWeek = now - 14 * MS_DAY;

    // ---- 1) Filter for "this week" and "last week" based on lastAt ----
    const isActive = (c: Counter) =>
      !c.archived && typeof c.lastAt === "number" && Number.isFinite(c.lastAt);

    const thisWeekCounters = counters.filter(
      (c) => isActive(c) && (c.lastAt as number) >= startOfThisWeek
    );

    const lastWeekCounters = counters.filter(
      (c) =>
        isActive(c) &&
        (c.lastAt as number) >= startOfLastWeek &&
        (c.lastAt as number) < startOfThisWeek
    );

    // "Check-ins this week" = # of counters you touched in the last 7 days
    const totalThisWeek = thisWeekCounters.length;

    // Active days = distinct calendar days in last 7 days where something was updated
    const activeDayKeys = new Set<string>();
    for (const c of thisWeekCounters) {
      const ts = c.lastAt as number;
      const dayKey = new Date(ts).toDateString();
      activeDayKeys.add(dayKey);
    }
    const activeDays = activeDayKeys.size;

    // Top counter = most recently updated in this week, fallback to most recent overall
    let topCounter = "Top counter";
    if (thisWeekCounters.length > 0) {
      const top = [...thisWeekCounters].sort(
        (a, b) => (b.lastAt as number) - (a.lastAt as number)
      )[0];
      topCounter = top.title;
    } else if (counters.length > 0) {
      const top = [...counters]
        .filter((c) => isActive(c))
        .sort((a, b) => (b.lastAt as number) - (a.lastAt as number))[0];
      if (top) topCounter = top.title;
    }

    const lastWeekTotal = lastWeekCounters.length;

    // ---- 2) Donut segments: category mix of all non-archived counters ----
    const byCategory: Record<CounterCategoryKey, number> = {
      work: 0,
      health: 0,
      home: 0,
      personal: 0,
      other: 0,
    };

    for (const c of counters) {
      if (c.archived) continue;
      const key = ((c.category as CounterCategoryKey) || "other") as CounterCategoryKey;
      byCategory[key] = (byCategory[key] ?? 0) + 1;
    }

    const segments: InsightSegment[] = (
      Object.keys(CATEGORY_META) as CounterCategoryKey[]
    )
      .map((key) => ({
        label: CATEGORY_META[key].label,
        value: byCategory[key] ?? 0,
        color: CATEGORY_META[key].color,
      }))
      .filter((seg) => seg.value > 0); // hide empty categories

    const total = totalThisWeek; // for donut center + snapshot
    const change = totalThisWeek - lastWeekTotal;
    const changePercent =
      lastWeekTotal > 0 ? Math.round((change / lastWeekTotal) * 100) : 0;
    const isUp = change >= 0;

    return {
      total,
      activeDays,
      topCounter,
      lastWeekTotal,
      segments,
      change,
      changePercent,
      isUp,
    };
  }, [counters]);

  return {
    total,
    activeDays,
    topCounter,
    lastWeekTotal,
    segments,
    change,
    changePercent,
    isUp,
  };
}
